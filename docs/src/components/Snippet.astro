---
// Renders a Typst snippet from `docs-site/snippets/<name>.typ` alongside
// its compiled SVG from `docs-site/public/diagrams/<name>.svg`.
//
// Code on top, rendered diagram below. Snippet sources are bundled at
// build time via Vite's `?raw` glob; the SVG is fetched by the browser
// from the public directory.

import { Code } from '@astrojs/starlight/components';
import { existsSync, statSync } from 'node:fs';
import { spawnSync } from 'node:child_process';
import { resolve } from 'node:path';

interface Props {
  name: string;
  caption?: string;
}

const { name, caption } = Astro.props;

// Bundle every snippet's source at build time. The keys are paths like
// "../../snippets/foo.typ"; values are the file contents as strings.
const sources = import.meta.glob('../../snippets/*.typ', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const sourceKey = `../../snippets/${name}.typ`;
const source = sources[sourceKey];
if (typeof source !== 'string') {
  throw new Error(
    `Snippet "${name}" not found. Add docs-site/snippets/${name}.typ.`,
  );
}

// Strip only the per-file build harness — `#import` lines (the package
// import + the `cetz` re-import some recipes do), `#set page`, and
// `#set text`. These are identical across snippets and never
// load-bearing for what the snippet is teaching.
//
// The `#pg.diagram(...) { ... }` wrapper stays. It is the canvas — it
// installs cetz-power's default style dictionary into ctx.style and
// (in HTML mode) wraps the result in `html.frame` so it renders as
// inline SVG. Without it the snippet doesn't compile to anything and
// callers couldn't copy-paste a working example. Hiding it from
// readers obscures the package's actual entry point, so we display
// what the source file actually contains.
//
// Highlighting trade-off: the Typst TextMate grammar can only
// tokenize `#`-led expressions at statement boundaries — it has no
// parser stack to know that the body inside `#pg.diagram({ ... })` is
// itself code mode. So inside the wrapper, only the call name and
// outer punctuation get distinct colors; deeper tokens render in the
// theme's default text colour. That's a known limitation of every
// shipped Typst grammar, not specific to this site.
const trimmed = source
  .split('\n')
  .filter((line) => {
    const t = line.trim();
    if (t.startsWith('#import')) return false;
    if (t.startsWith('#set page')) return false;
    if (t.startsWith('#set text')) return false;
    return true;
  })
  .join('\n')
  .trim();

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const svgFsPath = `./public/diagrams/${name}.svg`;
const srcFsPath = `./snippets/${name}.typ`;

// Dev-time safety net: rebuild this snippet's SVG on demand if it's
// stale relative to the source. The standalone `node --watch-path`
// snippet watcher in scripts/dev.mjs misses change events on some
// filesystems (notably Nextcloud-synced directories) so the SVG can
// drift behind the source. Vite always invalidates this component
// when its imported `.typ` source changes — that triggers Astro to
// re-render this Snippet, which gives us a reliable hook to recompile.
//
// In production the prebuilt diagrams from `npm run build:diagrams`
// are authoritative; we skip this to avoid spawning typst per page.
if (import.meta.env.DEV && existsSync(srcFsPath)) {
  const srcMtime = statSync(srcFsPath).mtimeMs;
  const svgMtime = existsSync(svgFsPath) ? statSync(svgFsPath).mtimeMs : 0;
  if (srcMtime > svgMtime) {
    const repoRoot = resolve('..');
    const result = spawnSync(
      'typst',
      ['compile', '--root', repoRoot, '--format', 'svg', srcFsPath, svgFsPath],
      { stdio: ['ignore', 'inherit', 'inherit'] },
    );
    if (result.status !== 0) {
      console.error(`✗ on-demand compile failed for snippet "${name}"`);
    }
  }
}

// Cache-bust the SVG URL with its file's mtime so browsers pick up the
// rebuilt diagram instead of serving the previously-cached SVG.
const cacheBust = existsSync(svgFsPath) ? statSync(svgFsPath).mtimeMs : Date.now();
const svgUrl = `${base}/diagrams/${name}.svg?v=${cacheBust}`;
---

<figure class="snippet">
  <div class="snippet__grid">
    <div class="snippet__code">
      <Code code={trimmed} lang="typ" />
    </div>
    <div class="snippet__diagram">
      <object type="image/svg+xml" data={svgUrl} aria-label={caption ?? name}></object>
    </div>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>
