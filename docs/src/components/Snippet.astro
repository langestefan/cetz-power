---
// Renders a Typst snippet from `docs-site/snippets/<name>.typ` alongside
// its compiled SVG from `docs-site/public/diagrams/<name>.svg`.
//
// Code on top, rendered diagram below. Snippet sources are bundled at
// build time via Vite's `?raw` glob; the SVG is fetched by the browser
// from the public directory.

import { Code } from '@astrojs/starlight/components';
import { existsSync, statSync } from 'node:fs';

interface Props {
  name: string;
  caption?: string;
}

const { name, caption } = Astro.props;

// Bundle every snippet's source at build time. The keys are paths like
// "../../snippets/foo.typ"; values are the file contents as strings.
const sources = import.meta.glob('../../snippets/*.typ', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const sourceKey = `../../snippets/${name}.typ`;
const source = sources[sourceKey];
if (typeof source !== 'string') {
  throw new Error(
    `Snippet "${name}" not found. Add docs-site/snippets/${name}.typ.`,
  );
}

// Strip the boilerplate header (the `#import` and `#set page` lines) so
// readers see only the part that actually changes between snippets.
const trimmed = source
  .split('\n')
  .filter((line) => {
    const t = line.trim();
    if (t.startsWith('#import')) return false;
    if (t.startsWith('#set page')) return false;
    return true;
  })
  .join('\n')
  .trim();

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Cache-bust the SVG URL with its file's mtime so browsers pick up the
// rebuilt diagram instead of serving the previously-cached SVG.
const svgFsPath = `./public/diagrams/${name}.svg`;
const cacheBust = existsSync(svgFsPath) ? statSync(svgFsPath).mtimeMs : Date.now();
const svgUrl = `${base}/diagrams/${name}.svg?v=${cacheBust}`;
---

<figure class="snippet">
  <div class="snippet__grid">
    <div class="snippet__code">
      <Code code={trimmed} lang="typ" />
    </div>
    <div class="snippet__diagram">
      <object type="image/svg+xml" data={svgUrl} aria-label={caption ?? name}></object>
    </div>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>
