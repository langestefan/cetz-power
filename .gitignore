node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build/tool caches
.cache/
.turbo/
*.tsbuildinfo

# Environment files (never commit secrets)
.env
.env.*
!.env.example

# ── Editor / OS cruft ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
.idea/
.vscode/

