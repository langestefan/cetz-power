# ── Typst ────────────────────────────────────────────────────────────
# Test compile artifacts
tests/*/out/

# Stray Typst outputs at the repo root (probe.png, ad-hoc test renders)
*.pdf
*.svg
*.png

# ── Astro / Starlight docs site (docs/) ──────────────────────────────
docs/node_modules/
docs/dist/
docs/.astro/
docs/public/diagrams/   # generated by `npm run build:diagrams`

